# Copy this file to `.env.local` and fill in the values.
# Do NOT commit `.env.local` or any file containing real secrets — `.gitignore`
# already excludes `.env*`.

# --- Review data sources ---------------------------------------------------

# Google Places API key — used to search for dental practices and fetch place
# details. https://developers.google.com/maps/documentation/places/web-service
GOOGLE_PLACES_API_KEY=

# SerpApi key — primary Google Maps reviews provider.
# https://serpapi.com/manage-api-key
SERPAPI_KEY=

# Outscraper API key — first fallback reviews provider.
# https://app.outscraper.com/profile
OUTSCRAPER_API_KEY=

# Apify API token — second fallback reviews provider.
# https://console.apify.com/account/integrations
APIFY_TOKEN=

# --- Database --------------------------------------------------------------

# PostgreSQL connection string used by Prisma (e.g. a Vercel Postgres or
# Neon/Supabase pooled connection URL).
POSTGRES_PRISMA_URL=

# --- Model inference endpoints ---------------------------------------------
# The sentiment and theme-classifier services are currently hardcoded in
# src/app/actions.ts. If you move them to environment variables (recommended
# for reuse), document them here, e.g.:
# SENTIMENT_URL=https://<your-host>/predict
# TOPICS_URL=https://<your-host>/predict
