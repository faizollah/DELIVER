<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results - DELIVER</title>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body class="bg-gray-50 font-sans text-gray-800">

    <div class="container mx-auto px-4 py-8">
        <header class="text-center mb-12">
            <a href="/" class="text-blue-600 hover:underline mb-4 inline-block">&larr; Back to Home</a>
            <h1 class="text-5xl font-bold text-blue-600 mb-2">Search for a Practice</h1>
        </header>

        <main class="max-w-4xl mx-auto">
            <div class="bg-white p-8 rounded-lg shadow-md mb-8">
                <form action="/search" method="POST">
                    <input type="text" name="query" class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-shadow duration-200" placeholder="e.g., 'dentist in Manchester'">
                    <button type="submit" class="w-full mt-4 bg-green-600 text-white font-bold py-3 px-6 rounded-lg hover:bg-green-700 transition-colors duration-300">Search</button>
                </form>
            </div>

            <% if (typeof practices !== 'undefined') { %>
                <div class="bg-white p-8 rounded-lg shadow-md">
                    <h2 class="text-2xl font-semibold text-gray-700 mb-4">Search Results</h2>
                    <% if (practices.length > 0) { %>
                        <ul class="space-y-4">
                            <% practices.forEach(practice => { %>
                                <li class="border-b pb-4">
                                    <a href="/analyze_practice/<%= practice.place_id %>" class="block hover:bg-gray-100 p-4 rounded-lg">
                                        <h3 class="text-xl font-semibold text-blue-600"><%= practice.name %></h3>
                                        <p class="text-gray-600"><%= practice.address %></p>
                                        <p class="text-yellow-500">Rating: <%= practice.rating %> (<%= practice.user_ratings_total %> reviews)</p>
                                    </a>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <p>No practices found for your search.</p>
                    <% } %>
                </div>
            <% } %>
        </main>
    </div>

</body>
</html>
