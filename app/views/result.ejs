<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analysis Result - DELIVER</title>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body class="bg-gray-50 font-sans text-gray-800">

    <div class="container mx-auto px-4 py-8">
        <header class="text-center mb-12">
            <a href="/analysis" class="text-blue-600 hover:underline mb-4 inline-block">&larr; Back to Analysis Hub</a>
            <h1 class="text-5xl font-bold text-blue-600 mb-2">Analysis Result</h1>
        </header>

        <main class="max-w-4xl mx-auto bg-white p-8 rounded-lg shadow-md">
            <div class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-700 mb-4">Original Review:</h2>
                <p class="text-gray-600 p-4 border rounded-lg bg-gray-50">"<%= text %>"</p>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-xl font-semibold text-gray-700 mb-2">Sentiment:</h3>
                    <p class="text-2xl font-bold <%= sentimentResult.sentiment === 'Positive' ? 'text-green-500' : 'text-red-500' %>"><%= sentimentResult.sentiment %></p>
                    <img src="<%= charts.sentimentImage %>" alt="Sentiment Chart" class="mt-4 rounded-lg shadow-sm">
                </div>
                <div>
                    <h3 class="text-xl font-semibold text-gray-700 mb-2">Themes:</h3>
                    <ul class="list-disc list-inside space-y-2">
                        <% multilabelResult.predicted_labels.forEach(label => { %>
                            <li class="text-gray-600"><%= label %></li>
                        <% }); %>
                    </ul>
                    <img src="<%= charts.multilabelImage %>" alt="Multilabel Chart" class="mt-4 rounded-lg shadow-sm">
                </div>
            </div>
        </main>
    </div>

</body>
</html>