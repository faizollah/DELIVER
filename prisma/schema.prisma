// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model SentimentLog {
  id         Int      @id @default(autoincrement())
  inputText  String
  sentiment  String
  confidence Float
  createdAt  DateTime @default(now())
}

model ReviewCache {
  placeId  String   @id
  reviews  Json
  cachedAt DateTime @default(now())
}
