{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "app/**",
                    "public/**",
                    "postcss.config.js",
                    "tailwind.config.js"
                ]
            }
        }
    ],
    "routes": [
        { "src": "/public/(.*)", "dest": "/public/$1" },
        { "src": "/(.*)", "dest": "index.js" }
    ]
}
